{
  "rules": [
    {
      "match": {
        "anyOf": [
          {
            "path": {
              "prefix": "/users"
            }
          },
          {
            "path": {
              "prefix": "/kingdoms"
            }
          },
          {
            "path": {
              "prefix": "/inventory"
            }
          }
        ]
      },
      "allow": {
        "condition": "request.auth != null"
      },
      "description": "Allow authenticated access to all collections"
    },
    {
      "match": {
        "path": {
          "prefix": "/users"
        }
      },
      "allow": {
        "condition": "resource.data.kingdom_id == request.auth.uid"
      },
      "description": "Users can only read their own kingdom data"
    },
    {
      "match": {
        "path": {
          "prefix": "/kingdoms"
        }
      },
      "allow": {
        "condition": "resource.data.owner_id == request.auth.uid || 'admin' in request.auth.token.roles"
      },
      "description": "Only kingdom owner or admin can modify kingdom"
    }
  ]
}
